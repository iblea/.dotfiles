{
    "name": "destination",
    "host": "1.1.1.1",
    "protocol": "sftp",
    "port": 22,
    "secure": true,
    "username": "user",
    "remotePath": "/home/user/",
    "privateKeyPath": "/home/.ssh/privkey",
    "uploadOnSave": true,
    "watcher": {
        "files": "**/*",
        "autoUpload": true,
        "autoDelete": true
    },
    "ignore": [
        "**/.git",
        "**/__pycache__",
        "/venv_*/",
        "**/*.pyc",
        "**/*.pyo",
        "**/*.pyd",
        "**/*.pyw",
        "**/*.pyz",
        "**/*.swp",
        "**/*.swo",
        "**/*.swn",
        "**/*.swm"
    ]
}
