#!/bin/bash

TMUX_COMMAND=( tmux )

if [ -z "$TMUX" ]; then
    if [ -n "$SSH_CONNECTION" ] || [ -n "$SSH_CLIENT" ]; then
        if [ -z "$LC_TMUX" ]; then
            echo "You are not in tmux. (ssh)"
            echo "This command can only be used in tmux (ssh)."
            exit 1
        elif [ -z "$LC_TMUX_SOCKET" ]; then
            echo "SSH - TMUX must need LC_TMUX_SOCKET env variable."
            exit 1
        fi

        TMUX_COMMAND=( tmux -S "${LC_TMUX_SOCKET}" )
        echo "INFO: You are operating LOCAL TMUX in SSH."
    else
        echo "You are not in tmux."
        echo "This command can only be used in tmux."
        exit 1
    fi
fi


if [ "$#" -le 0 ]; then
    echo "Wrong Argument."
    echo "Show Help: sendtmuxpane -h"
    exit 1
elif [ "$#" -eq 1 ]; then
    if [ "$@" = "-h" ] || [ "$@" = "--help" ]; then
        echo "Argument"
        echo "-h, --help: show help"
        echo ""
        echo "First Argument: <window number>.<pane number>"
        echo "  ex: sendtmuxpane 2 -> window 2, pane 1"
        echo "  ex: sendtmuxpane 2.2 -> window 2, pane 2"
        echo "  ex: sendtmuxpane .2 -> current window, pane 2"
        echo ""
        echo "Other Arguments: tmux send-keys options"
        echo ""
        echo "WARNING: tmux command parser treats the following characters specially."
        echo "  ';' (semicolon) - command separator. Escape: \\;"
        echo "  '#' (hash)      - comment (text after # is ignored). Escape: \\#"
        echo "  '\\' (backslash at EOL) - line continuation. Escape: \\\\"
        echo ""
        echo "NOTE: To send literal backslash (e.g. \\t, \\n), use -l flag."
        echo "  Without -l: \\t may be interpreted as Tab key by the shell."
        echo "  With    -l: \\t is sent as literal characters (backslash + t)."
        echo ""
        echo "Example:"
        echo "  sendtmuxpane 2 \"SELECT 1\" '\\;' C-m"
        echo "  sendtmuxpane 2 \"echo hello\" '\\#' \"world\" C-m"
        echo "  sendtmuxpane 2 -l 'echo \\ttest' && sendtmuxpane 2 C-m"
        exit 0
    fi
fi

target="$1"
shift

# Pane Argument 파싱: <window>.<pane> / <window> / .<pane>
case "$target" in
    .*)
        # ".pane" 형태: 명령이 실행되는 페인($TMUX_PANE)의 윈도우 번호를 앞에 채움
        # 타겟 없는 '#I'는 "활성 윈도우"를 반환하므로, 명령 입력 후 다른 윈도우로
        # 전환하면 엉뚱한 윈도우를 잡는다. $TMUX_PANE 기준으로 고정한다.
        if [ -n "$TMUX_PANE" ]; then
            display_window=$(${TMUX_COMMAND[@]} display-message -p -t "$TMUX_PANE" '#I')
        else
            display_window=$(${TMUX_COMMAND[@]} display-message -p '#I')
        fi
        target="${display_window}${target}"
        ;;
    *.*)
        # "window.pane" 형태: 그대로 사용
        display_window="${target%%.*}"
        ;;
    *)
        # "window"만 (점 없음): window의 첫 페인을 명시 (2 -> 2.1)
        # 점 없는 단일 숫자는 tmux가 "현재 윈도우의 pane N"으로 해석하므로 명시 필요
        display_window="$target"
        pane_base=$(${TMUX_COMMAND[@]} show-options -gv pane-base-index 2>/dev/null)
        target="${target}.${pane_base:-0}"
        ;;
esac

windowlist="$(${TMUX_COMMAND[@]} list-windows | grep -P '^[0-9]+:' | awk -F ':' '{print $1}')"
is_exist=$(echo "$windowlist" | grep "^$display_window$")
if [ -z "$is_exist" ]; then
    echo "window number is wrong"
    exit 1
fi

if [ "$(${TMUX_COMMAND[@]} display -t ${target} -p '#{pane_in_mode}')" = "1" ]; then
    echo "INFO: Copy mode in ${target}. Cancel copy mode first."
    ${TMUX_COMMAND[@]} send-keys -t ${target} -X cancel
fi

${TMUX_COMMAND[@]} send-keys -t "$target" "$@"
ret_code="$?"
if [ $ret_code -eq 0 ]; then
    echo "command send successfully [${ret_code}]"
else
    echo "WARNING: return code is not zero. check tmux window.. [${ret_code}]"
fi

