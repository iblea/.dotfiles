#!/bin/bash

DEFAULT_EDITOR="vi"
NVIM_IDE=0

if [ -z "$(command -v tmux)" ]; then
    echo "tmux command not found"
    exit 1
fi

if [ -z "$(command -v gemini)" ]; then
    echo "gemini is not installed"
    echo "https://geminicli.com/docs/get-started/installation/"
    echo "npm install -g @google/gemini-cli"
    exit 1
fi

if [ $# -eq 1 ]; then
    if [[ "$1" = "-h" ]] || [[ "$1" = "--help" ]]; then
        gemini --help
        exit $?
    elif [[ "$1" = "update" ]] || [[ "$1" = "--update" ]] || [[ "$1" = "upgrade" ]] || [[ "$1" = "--upgrade" ]]; then
        npm install -g @google/gemini-cli@latest
        if [ $? -ne 0 ]; then
            echo "update error"
            echo "rm -rf \"$(npm root -g)/@google/gemini-cli\""
            echo "rm -rf \"$(npm root -g)/@google/\".gemini-cli-*"
            echo "npm cache clean --force"
            echo "npm uninstall -g @google/gemini-cli"
            echo "npm install -g @google/gemini-cli"
        fi
        exit $?
    elif [[ "$1" = "-v" ]] || [[ "$1" = "-V" ]] || [[ "$1" = "version" ]] || [[ "$1" = "--version" ]]; then
        gemini --version
        exit $?
    elif [[ "$1" = "changelog" ]] || [[ "$1" = "ch" ]] || [[ "$1" = "-ch" ]] || [[ "$1" = "--changelog" ]]; then
        echo "release note: https://geminicli.com/docs/changelogs/latest/"
		echo "changelog   : https://geminicli.com/docs/changelogs/"
        echo "github  link: https://github.com/google-gemini/gemini-cli/releases"
        exit 0
    elif [[ "$1" = "ls" ]] || [[ "$1" = "-ls" ]] || [[ "$1" = "--list-sessions" ]]; then
        gemini --list-sessions
        exit 0
    fi
fi

if [ $# -eq 2 ]; then
    if [ "$1" = "ds" ] || [ "$1" = "-ds" ] || [ "$1" = "--delete-session" ]; then
        gemini --delete-session $2
        gemini --list-sessions
        exit 0
    fi
fi

for arg in "$@"; do
    if [[ "$arg" = "vs" ]] || [[ "$arg" = "-vs" ]] || [[ "$arg" = "code" ]] || [[ "$arg" = "-code" ]]; then
        export EDITOR="code"
        shift
    elif [[ "$arg" = "vi" ]] || [[ "$arg" = "-vi" ]]; then
        if [ -n "$(command -v nvim)" ]; then
            export EDITOR="nvim"
        else
            export EDITOR="vim"
        fi
        NVIM_IDE=1
        shift
    elif [[ "$arg" = "vim" ]] || [[ "$arg" = "-vim" ]]; then
        export EDITOR="vim"
		shift
        NVIM_IDE=1
    elif [[ "$arg" = "nvi" ]] || [[ "$arg" = "-nvi" ]] || [[ "$arg" = "nvim" ]] || [[ "$arg" = "-nvim" ]]; then
        export EDITOR="nvim"
        NVIM_IDE=1
        shift
    fi
done

if [ -z "$EDITOR" ]; then
    if [[ "$DEFAULT_EDITOR" = "code" ]]; then
        export EDITOR="code"
    elif [[ "$DEFAULT_EDITOR" = "vi" ]]; then
        if [ -n "$(command -v nvim)" ]; then
            export EDITOR="nvim"
        else
            export EDITOR="vim"
        fi
    else
        if [ -n "$GIT_ASKPASS" ]; then
            export EDITOR="code"
        elif [ -n "$(command -v nvim)" ]; then
            export EDITOR="nvim"
        else
            export EDITOR="vim"
        fi
    fi
fi

if [[ "$EDITOR" = "nvim" ]]; then
    export EDITOR="codenvim"
elif [[ "$EDITOR" = "vim" ]]; then
    export EDITOR="codevim"
fi


