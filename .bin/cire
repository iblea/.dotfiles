#!/bin/bash

if [ -z "$(git diff --cached --name-only 2>/dev/null)" ]; then
    echo "no staged."
    exit 1
fi

if command -v jq &>/dev/null; then
    # ===== cires (stream-json, 실시간 출력) =====

    set +m

    tmpfifo=$(mktemp -u)
    mkfifo "$tmpfifo"

    # claude background 실행 (PID 추적 가능)
    ANTHROPIC_API_KEY="" claude -p --output-format stream-json --verbose --include-partial-messages ";cire $*" > "$tmpfifo" 2>/dev/null &
    claude_pid=$!

    # 스피너
    dots=("." ".." "...")
    (
        i=0
        printf "recommand commit message with claude (streaming)\n"
        echo ""
        while true; do
            printf "\rplease wait%-3s" "${dots[$((i % 3))]}"
            i=$((i + 1))
            sleep 0.5
        done
    ) &
    spinner_pid=$!

    cleanup() {
        kill "$spinner_pid" 2>/dev/null
        kill "$claude_pid" 2>/dev/null
        wait "$spinner_pid" 2>/dev/null
        wait "$claude_pid" 2>/dev/null
        printf "\r\033[K"
        rm -f "$tmpfifo"
    }
    trap 'cleanup; exit 130' INT

    first_message=true

    while IFS= read -r line; do
        text=$(printf '%s' "$line" | jq -rj 'select(.type == "stream_event" and .event.delta.type? == "text_delta") | .event.delta.text' 2>/dev/null)
        if [ -n "$text" ]; then
            if $first_message; then
                kill "$spinner_pid" 2>/dev/null
                wait "$spinner_pid" 2>/dev/null
                printf "\r\033[K"
                first_message=false
            fi
            printf "%s" "$text"
        fi
    done < "$tmpfifo"

    # 텍스트 없이 끝난 경우 스피너 정리
    if $first_message; then
        kill "$spinner_pid" 2>/dev/null
        wait "$spinner_pid" 2>/dev/null
        printf "\r\033[K"
    fi

    trap - INT
    wait "$claude_pid" 2>/dev/null
    rm -f "$tmpfifo"
    echo

else
    # ===== cire (text, 일괄 출력) =====

    tmpfile=$(mktemp)

    # job control 메시지 숨기기
    set +m

    # OS에 따라 script 명령 분기 (macOS: BSD script, Linux: GNU script)
    if [ "$(uname)" = "Darwin" ]; then
        CIRE_OUT="$tmpfile" CIRE_ARGS=";cire $*" \
            script -q /dev/null sh -c 'ANTHROPIC_API_KEY="" claude -p --output-format text "$CIRE_ARGS" > "$CIRE_OUT" 2>&1' > /dev/null 2>&1 &
    else
        CIRE_OUT="$tmpfile" CIRE_ARGS=";cire $*" \
            script -qc 'ANTHROPIC_API_KEY="" claude -p --output-format text "$CIRE_ARGS" > "$CIRE_OUT" 2>&1' /dev/null > /dev/null 2>&1 &
    fi
    pid=$!

    cleanup() {
        kill "$pid" 2>/dev/null
        wait "$pid" 2>/dev/null
        printf "\r\033[K"
        rm -f "$tmpfile"
    }
    trap 'cleanup; exit 130' INT

    # 스피너
    dots=("." ".." "...")
    i=0
    printf "recommand commit message with claude\n"
    echo ""
    while kill -0 "$pid" 2>/dev/null; do
        printf "\rplease wait%-3s" "${dots[$((i % 3))]}"
        i=$((i + 1))
        sleep 0.5
    done

    trap - INT
    printf "\r\033[K"
    wait "$pid"
    cat "$tmpfile"
    rm -f "$tmpfile"

fi
