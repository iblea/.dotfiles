#     elif [[ "$opt" = "-h" ]] || [[ "$opt" = "-H" ]] || [[ "$opt" = "--head" ]]; then
#         ((i++))
#         HEAD_OPT="${!i}"
#     else
#         OTHER_OPTS+=("$opt")
#     fi
# done
# echo "TAIL_OPT: $TAIL_OPT"
# echo "HEAD_OPT: $HEAD_OPT"
# echo "OTHER_OPT: ${OTHER_OPTS[@]}"

if [ -n "$TAIL_OPT" ] && [ $TAIL_OPT -ne 0 ]; then
    ${TMUX_COMMAND[@]} capture-pane -t $target -p -E $(($(${TMUX_COMMAND[@]} display -p -t $target '#{pane_height}') - 1)) ${OTHER_OPTS[@]} | sed -e :a -e '/^\n*$/{$d;N;ba}' | tail -n $TAIL_OPT
elif [ -n "$HEAD_OPT" ] && [ $HEAD_OPT -ne 0 ]; then
    ${TMUX_COMMAND[@]} capture-pane -t $target -p -E $(($(${TMUX_COMMAND[@]} display -p -t $target '#{pane_height}') - 1)) ${OTHER_OPTS[@]} | sed -e :a -e '/^\n*$/{$d;N;ba}' | tail -n $HEAD_OPT
else
    ${TMUX_COMMAND[@]} capture-pane -t $target -p -E $(($(${TMUX_COMMAND[@]} display -p -t $target '#{pane_height}') - 1)) ${OTHER_OPTS[@]} | sed -e :a -e '/^\n*$/{$d;N;ba}'
fi

