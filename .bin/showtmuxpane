#!/bin/bash

TMUX_COMMAND=( tmux )

if [ -z "$TMUX" ]; then
    if [ -n "$SSH_CONNECTION" ] || [ -n "$SSH_CLIENT" ]; then
        if [ -z "$LC_TMUX" ]; then
            echo "You are not in tmux. (ssh)"
            echo "This command can only be used in tmux (ssh)."
            exit 1
        elif [ -z "$LC_TMUX_SOCKET" ]; then
            echo "SSH - TMUX must need LC_TMUX_SOCKET env variable."
            exit 1
        fi

        TMUX_COMMAND=( tmux -S "${LC_TMUX_SOCKET}" )
        echo "INFO: You are operating LOCAL TMUX in SSH."
    else
        echo "You are not in tmux."
        echo "This command can only be used in tmux."
        exit 1
    fi
fi


if [ "$#" -le 0 ]; then
    echo "Wrong Argument."
    echo "Show Help: showtmuxpane -h"
    exit 1
elif [ "$#" -eq 1 ]; then
    if [ "$@" = "-h" ] || [ "$@" = "--help" ]; then
        echo "Argument"
        echo "-h, --help: show help"
        echo ""
        echo "First Argument: <window number>.<pane number>"
        echo "  ex: showtmuxpane 2 -> window 2, pane 1"
        echo "  ex: showtmuxpane 2.2 -> window 2, pane 2"
        echo ""
        echo "Other Arguments: tmux capture-pane options"
        echo "-S: <start line>"
        echo ""
        echo "The -E option is set as the default value, and this cannot be changed."
        echo "    Default Value: \$((\$(tmux display -p -t <window_number> '#{pane_height}') - 1))"
        echo "The p option is enabled, and this cannot be changed."
        exit 0

        echo "Argument"
        echo "-h, --help: show help"
        echo ""
        echo "-t: <window number>"
        echo "-S: <start line>"
        echo ""
        echo "The -E option is set as the default value, and this cannot be changed."
        echo "    Default Value: \$((\$(tmux display -p -t <window_number> '#{pane_height}') - 1))"
        echo "The p option is enabled, and this cannot be changed."
        exit 0
    fi
fi

# display_window="$1"
target="$1"
display_window=$(echo "$target" | awk -F '.' '{print $1}')
shift
windowlist="$(${TMUX_COMMAND[@]} list-windows | grep -P '^[0-9]+:' | awk -F ':' '{print $1}')"
is_exist=$(echo "$windowlist" | grep "^$display_window$")
if [ -z "$is_exist" ]; then
    echo "window number is wrong"
    exit 1
fi


TAIL_OPT=0
HEAD_OPT=0
OTHER_OPTS=()

while [ $# -gt 0 ]; do
    case "$1" in
        -t|-T|--tail) TAIL_OPT="$2"; shift ;;
        -h|-H|--head) HEAD_OPT="$2"; shift ;;
        *) OTHER_OPTS+=("$1") ;;
    esac
    shift
done

