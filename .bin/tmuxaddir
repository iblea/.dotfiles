#!/bin/bash

TMUX_COMMAND=( tmux )

if [ -z "$TMUX" ]; then
    if [ -n "$SSH_CONNECTION" ] || [ -n "$SSH_CLIENT" ]; then
        if [ -z "$LC_TMUX" ]; then
            echo "You are not in tmux. (ssh)"
            echo "This command can only be used in tmux (ssh)."
            exit 1
        elif [ -z "$LC_TMUX_SOCKET" ]; then
            echo "SSH - TMUX must need LC_TMUX_SOCKET env variable."
            exit 1
        fi

        TMUX_COMMAND=( tmux -S "${LC_TMUX_SOCKET}" )
        echo "INFO: You are operating LOCAL TMUX in SSH."
    else
        echo "You are not in tmux."
        echo "This command can only be used in tmux."
        exit 1
    fi
fi


if [ "$#" -le 0 ]; then
    echo "Wrong Argument."
    echo "Show Help: tmuxaddir -h"
    exit 1
elif [ "$#" -eq 1 ]; then
    if [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
        echo "Argument"
        echo "-h, --help: show help"
        echo ""
        echo "First Argument: <window number>.<pane number>"
        echo "  ex: tmuxaddir 2   -> window 2, pane 1"
        echo "  ex: tmuxaddir 2.2 -> window 2, pane 2"
        echo "  ex: tmuxaddir .2  -> current window, pane 2"
        echo ""
        echo "Description:"
        echo "  Resolve the absolute current path of the target window/pane,"
        echo "  then send '/add-dir <path>' (followed by Enter) to the CURRENT pane."
        echo "  Intended for adding the target pane's CWD to the Claude Code"
        echo "  session that is running in the current pane."
        exit 0
    fi
fi

target="$1"

# Pane Argument 파싱: <window>.<pane> / <window> / .<pane>
case "$target" in
    .*)
        # ".pane" 형태: 명령이 실행되는 페인($TMUX_PANE)의 윈도우 번호를 앞에 채움
        # 타겟 없는 '#I'는 "활성 윈도우"를 반환하므로, 명령 입력 후 다른 윈도우로
        # 전환하면 엉뚱한 윈도우를 잡는다. $TMUX_PANE 기준으로 고정한다.
        if [ -n "$TMUX_PANE" ]; then
            display_window=$(${TMUX_COMMAND[@]} display-message -p -t "$TMUX_PANE" '#I')
        else
            display_window=$(${TMUX_COMMAND[@]} display-message -p '#I')
        fi
        target="${display_window}${target}"
        ;;
    *.*)
        # "window.pane" 형태: 그대로 사용
        display_window="${target%%.*}"
        ;;
    *)
        # "window"만 (점 없음): window의 첫 페인을 명시 (2 -> 2.1)
        # 점 없는 단일 숫자는 tmux가 "현재 윈도우의 pane N"으로 해석하므로 명시 필요
        display_window="$target"
        pane_base=$(${TMUX_COMMAND[@]} show-options -gv pane-base-index 2>/dev/null)
        target="${target}.${pane_base:-0}"
        ;;
esac

windowlist="$(${TMUX_COMMAND[@]} list-windows | grep -P '^[0-9]+:' | awk -F ':' '{print $1}')"
is_exist=$(echo "$windowlist" | grep "^$display_window$")
if [ -z "$is_exist" ]; then
    echo "window number is wrong"
    exit 1
fi

path="$(${TMUX_COMMAND[@]} display-message -p -t "$target" '#{pane_current_path}')"
if [ -z "$path" ]; then
    echo "ERROR: Failed to get current path of target '$target'."
    exit 1
fi
# path="${path}/"

current_pane="${TMUX_PANE}"
if [ -z "$current_pane" ]; then
    echo "ERROR: \$TMUX_PANE is empty. Cannot determine current pane."
    exit 1
fi

${TMUX_COMMAND[@]} send-keys -t "$current_pane" -l "/add-dir $path"
ret_code="$?"
if [ $ret_code -ne 0 ]; then
    echo "WARNING: send-keys (text) return code is not zero. [${ret_code}]"
    exit $ret_code
fi

${TMUX_COMMAND[@]} send-keys -t "$current_pane" Enter
ret_code="$?"
if [ $ret_code -eq 0 ]; then
    echo "sent to ${current_pane}: /add-dir $path"
else
    echo "WARNING: send-keys (Enter) return code is not zero. [${ret_code}]"
    exit $ret_code
fi
